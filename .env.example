# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Admin Key (for server-side admin operations)
# You can use either SUPABASE_SERVICE_ROLE_KEY or SUPABASE_SECRET_KEY
# IMPORTANT: Keep this secret! Never commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# OR
SUPABASE_SECRET_KEY=your_supabase_service_role_key

# Admin Login Credentials (required for /admin/login and /admin/setup)
# Set in .env locally or in Railway Variables when deployed. Supabase is not used for credentials.
USERNAME=your_admin_username
PASSWORD=your_admin_password

# Site URL (Optional - can be configured via site-config.json or admin UI)
# This is used for generating absolute URLs in metadata
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Node Environment
NODE_ENV=development

# Google Drive service account (pick ONE approach):
# 1) JSON file path (recommended locally):
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=ruutuli-07f405959e17.json
# GOOGLE_APPLICATION_CREDENTIALS=C:/absolute/path/to/key.json
# 2) Inline JSON or base64:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# 3) Flat vars (same fields as the .json file):
# GOOGLE_CLIENT_EMAIL=your-bot@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Drive API key — for markdown images shared as "Anyone with the link" (without sharing each
# file to the service account). Enable "Google Drive API" in Cloud Console.
# GOOGLE_API_KEY=your_api_key_here

